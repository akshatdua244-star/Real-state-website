{
  "name": "luxeproperty-website",
  "version": "1.0.0",
  "description": "Premium Luxury Real Estate Website with Lead Generation",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && nodemon server.js",
    "build": "cd frontend && npm run build",
    "start": "node backend/server.js",
    "test": "jest"
  },
  "keywords": ["real-estate", "luxury", "properties", "lead-generation"],
  "author": "LuxeProperty Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.0"
  }
}
